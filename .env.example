RATIO_SERVER_BIND=127.0.0.1
RATIO_SERVER_PORT=8787
RATIO_CORS_ORIGIN=http://localhost:5173
RATIO_MAX_BACKUP_BYTES=2097152
RATIO_REGISTRATION_INVITE_CODE=
RATIO_ALLOW_OPEN_REGISTRATION=false

# Prefer a full OpenAI Responses API endpoint.
RATIO_AI_RESPONSES_URL=
# Legacy name still works for compatibility.
RATIO_AI_CHAT_URL=
# Or set RATIO_AI_BASE_URL plus RATIO_AI_RESPONSES_PATH.
RATIO_AI_BASE_URL=
RATIO_AI_RESPONSES_PATH=/v1/responses
RATIO_AI_API_KEY=
RATIO_AI_MODEL=gpt-5.2
RATIO_AI_REASONING_EFFORT=high
RATIO_AI_UPSTREAM_TIMEOUT_MS=120000
RATIO_AI_MAX_RESPONSE_BYTES=2097152
RATIO_AI_RATE_LIMIT_PER_MINUTE=30
RATIO_AI_DAILY_REQUEST_LIMIT=200
RATIO_AI_MAX_MESSAGES=30
RATIO_AI_MAX_MESSAGE_CHARS=12000
RATIO_AI_MAX_TOTAL_MESSAGE_CHARS=60000
RATIO_AI_ALLOW_HTTP_UPSTREAM=false
RATIO_AI_ALLOW_PRIVATE_UPSTREAM=false
RATIO_TELEMETRY_MAX_DAILY_BYTES=5242880
RATIO_TELEMETRY_RETENTION_DAYS=30
RATIO_TRUST_PROXY=false
RATIO_AUTH_RATE_LIMIT_PER_MINUTE=60
RATIO_AUTH_MAX_FAILED_ATTEMPTS=8
RATIO_AUTH_LOCKOUT_MS=300000
RATIO_AUTH_FAILURE_WINDOW_MS=900000
RATIO_AUTH_CACHE_TTL_MS=300000
RATIO_REGISTER_RATE_LIMIT_PER_MINUTE=30
RATIO_MAX_PASSWORD_CHARS=256
RATIO_ADMIN_USERNAME=
RATIO_ADMIN_PASSWORD=
RATIO_ADMIN_RATE_LIMIT_PER_MINUTE=300
